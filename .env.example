# ======================================================================
#  מלא את השדות האלה (Twilio — הדרך הראשית ב-README).
# ======================================================================

# מפתח מ-https://openrouter.ai/keys
OPENROUTER_KEY=

# מ-Twilio Console (העמוד הראשי)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# מספר ה-sandbox של Twilio
TWILIO_FROM=whatsapp:+14155238886

# מי מורשה לכתוב לבוט (הבוט עונה רק להם). אפשר כמה מספרים מופרדים בפסיק —
# למשל המשתמש (החבר) + אתה לבדיקה:
#   ALLOWED_WA_ID=whatsapp:+972526509692,whatsapp:+972500000000
ALLOWED_WA_ID=whatsapp:+972500000000

# הודעת פתיחה שנשלחת לכל מספר מורשה כשהבוט עולה (ריק = לא לשלוח)
STARTUP_MESSAGE=🤖 הבוט מחובר ומוכן! כתוב לי הודעה ואענה.

# כתובת ציבורית של השירות (ngrok מקומית, או https://<app>.fly.dev בענן)
PUBLIC_URL=

# ----------------------------------------------------------------------
#  אופציונלי
# ----------------------------------------------------------------------

# זיכרון שיחה מתמשך (Upstash Redis). בלי זה — נמחק ב-redeploy.
REDIS_URL=

# ======================================================================
#  מתקדם — רק אם משתמשים במתאם Baileys המקומי (baileys/) במקום Twilio
# ======================================================================
# PAIR_NUMBER=          # מספר הבוט הייעודי; מדפיס קוד צימוד במקום QR
# LOCAL_TOKEN=          # סיסמה בין הגשר לשירות הליבה
# CORE_URL=http://127.0.0.1:8090

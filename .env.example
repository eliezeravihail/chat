# --- WhatsApp (Meta / Facebook Graph API) ---
# Permanent access token from Meta Business
WA_TOKEN=
# Phone number ID from Meta Business (NOT the phone number itself)
WA_PHONE_ID=
# Arbitrary string; must match what you type in Meta's webhook verification UI
WA_VERIFY_TOKEN=
# App secret, used to validate the X-Hub-Signature-256 header
WA_APP_SECRET=
# The only wa_id allowed to talk to the bot, e.g. 9725XXXXXXXX (no + or spaces)
ALLOWED_WA_ID=

# --- OpenRouter ---
# API key from https://openrouter.ai/keys
OPENROUTER_KEY=

# --- Optional ---
# Upstash / Redis URL for persistent history & model selection.
# If unset, the bot keeps state in memory (fine for a single instance).
REDIS_URL=

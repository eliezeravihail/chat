# קובץ הגדרות לגרסת Twilio (הרצה מקומית). בענן — הערכים באים מ-GitHub Secrets,
# לא מהקובץ הזה. העתק ל-.env ומלא. הבוט טוען אותו לבד (בלי source).

# --- חובה ---
OPENROUTER_KEY=              # מ-https://openrouter.ai/keys
TWILIO_ACCOUNT_SID=          # מ-Twilio Console
TWILIO_AUTH_TOKEN=           # מ-Twilio Console
TWILIO_FROM=whatsapp:+14155238886          # מספר ה-sandbox
ALLOWED_WA_ID=whatsapp:+972500000000       # מי מורשה (אפשר כמה, בפסיקים)

# --- אופציונלי ---
DEFAULT_MODEL=hy3            # מודל ברירת מחדל (hy3 / auto / claude / gpt ...)
STARTUP_MESSAGE=🤖 הבוט מחובר ומוכן! כתוב לי הודעה ואענה.
REDIS_URL=                   # Upstash — זיכרון ששורד restart (ריק = זיכרון בלבד)
MEMORY_KEY=                  # אם מוגדר — הזיכרון נשמר מוצפן ב-Redis (openssl rand -base64 32)
POLL_SECONDS=4              # כל כמה שניות לבדוק הודעות חדשות
SHOW_MODEL=1               # 1 = הוסף בסוף כל תשובה איזה מודל ענה

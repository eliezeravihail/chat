# =====================================================================
#  Choose ONE adapter. Default is Twilio (no Facebook account needed).
#  APP_MODULE selects it: twilio_bot:app (default) or wa_bot:app (Meta).
# =====================================================================
APP_MODULE=twilio_bot:app

# --- Twilio WhatsApp (twilio_bot) ------------------------------------
# Account SID + Auth Token from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender number. Sandbox default is whatsapp:+14155238886
TWILIO_FROM=whatsapp:+14155238886
# Public https URL of this service (for Twilio signature validation)
PUBLIC_URL=https://your-app.fly.dev

# --- Meta WhatsApp Cloud API (wa_bot) — only if APP_MODULE=wa_bot:app -
# WA_TOKEN=
# WA_PHONE_ID=
# WA_VERIFY_TOKEN=
# WA_APP_SECRET=

# --- Shared ----------------------------------------------------------
# The only number allowed to talk to the bot.
#   Twilio: whatsapp:+9725XXXXXXXX   Meta: 9725XXXXXXXX
# The "whatsapp:" prefix and "+" are optional — normalized either way.
ALLOWED_WA_ID=

# API key from https://openrouter.ai/keys
OPENROUTER_KEY=

# Optional: Upstash / Redis URL for persistent history & model selection.
# If unset, the bot keeps state in memory (lost on restart).
REDIS_URL=

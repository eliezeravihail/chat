# ======================================================================
#  מלא את 4 השורות האלה (לשתי הדרכים ב-README). השאר — השאר ריק.
# ======================================================================

# מפתח מ-https://openrouter.ai/keys
OPENROUTER_KEY=

# המספר שלך — זה שכותב לבוט (ספרות בלבד, למשל 972500000000)
ALLOWED_WA_ID=

# מספר הבוט הייעודי — שאליו הוא מתחבר (ספרות בלבד). מדפיס קוד צימוד במקום QR.
PAIR_NUMBER=

# סיסמה כלשהי שמגנה על השירות המקומי
LOCAL_TOKEN=

# ----------------------------------------------------------------------
#  אופציונלי
# ----------------------------------------------------------------------

# זיכרון שיחה מתמשך (Upstash Redis). בלי זה — הזיכרון נמחק ב-restart.
REDIS_URL=

# היכן גשר ה-Node מגיע לשירות הליבה (ברירת מחדל תקינה לרוב)
CORE_URL=http://127.0.0.1:8090

# ======================================================================
#  מתקדם — רק אם משתמשים במתאמי Twilio/Meta הרשמיים (לא נדרש לדרכים 1/2)
# ======================================================================
# APP_MODULE=twilio_bot:app
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=whatsapp:+14155238886
# PUBLIC_URL=https://your-app.fly.dev
# WA_TOKEN=
# WA_PHONE_ID=
# WA_VERIFY_TOKEN=
# WA_APP_SECRET=
